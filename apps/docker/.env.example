# ─── Base de datos (Postgres en Docker) ──────────────────────────
# El docker-compose levanta un Postgres en el servicio `db`.
# Cambia credenciales/puerto aquí si lo necesitas.
POSTGRES_USER=apothecary
POSTGRES_PASSWORD=apothecary
POSTGRES_DB=apothecary_db
POSTGRES_PORT=5432

# ─── API (NestJS en Docker, servicio `api`) ──────────────────────
JWT_SECRET=dev-secret-cambiar-en-produccion
WEB_ORIGIN=http://localhost:3000
# Qué sembrar al arrancar el contenedor de la API:
#   none (default) · base (solo admin) · demo (base + datos de demo)
SEED_MODE=demo

# ─── Túnel (Cloudflare, servicio `cloudflared`) ──────────────────
# Único punto de entrada del stack: expone la web (http://web:3000).
# Por defecto usa un quick tunnel (URL aleatoria, ver logs del
# contenedor). Para un túnel con dominio propio, crea el túnel en
# Zero Trust, pega su token aquí y cambia el `command` en el compose.
TUNNEL_TOKEN=

# ─── Desarrollo: publicar puertos al host ────────────────────────
# En producción ningún servicio publica puertos (solo el túnel).
# Descomenta para exponer Postgres (Prisma Studio), web y api:
# COMPOSE_PATH_SEPARATOR=:
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# POSTGRES_PORT arriba; opcionales:
# WEB_PORT=3000
# API_PORT=4000
