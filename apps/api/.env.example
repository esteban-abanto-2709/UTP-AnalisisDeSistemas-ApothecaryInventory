# ─── Conexión a PostgreSQL ────────────────────────────────────────
# Apunta a la Postgres del docker-compose (apps/docker). En local, el
# override docker-compose.dev.yml publica el puerto 5432 al host.
# Credenciales por defecto: apps/docker/.env.example
DATABASE_URL="postgresql://apothecary:apothecary@localhost:5432/apothecary_db?schema=public"

# Puerto del servidor NestJS
PORT=4000

# ─── Autenticación ────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión (usa un valor aleatorio largo)
JWT_SECRET="dev-secret-cambiar-en-produccion"

# Origen del frontend permitido por CORS (cookies con credentials)
WEB_ORIGIN="http://localhost:3000"
