generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  VENDEDOR
  ADMINISTRADOR
}

enum TipoDocumento {
  DNI
  RUC
}

model Medicamento {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  precio    Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lotes Lote[]

  @@map("medicamentos")
}

model Lote {
  id               Int         @id @default(autoincrement())
  codigo           String
  medicamentoId    Int
  medicamento      Medicamento @relation(fields: [medicamentoId], references: [id])
  fechaVencimiento DateTime    @db.Date
  stockInicial     Int
  stockActual      Int
  descuento        Decimal     @default(0) @db.Decimal(5, 2)
  activo           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([medicamentoId, codigo])
  @@index([medicamentoId, fechaVencimiento])
  @@map("lotes")
}

model Cliente {
  id              Int           @id @default(autoincrement())
  tipoDocumento   TipoDocumento
  numeroDocumento String        @unique
  nombre          String
  telefono        String?
  direccion       String?
  email           String?
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("clientes")
}

model Empleado {
  id           Int      @id @default(autoincrement())
  dni          String   @unique @db.VarChar(8)
  nombre       String
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("empleados")
}
