generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  VENDEDOR
  ADMINISTRADOR
}

enum TipoDocumento {
  DNI
  RUC
}

enum TipoComprobante {
  BOLETA
  FACTURA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  YAPE_PLIN
}

model Medicamento {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  precio    Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lotes    Lote[]
  detalles DetalleVenta[]

  @@map("medicamentos")
}

model Lote {
  id               Int         @id @default(autoincrement())
  codigo           String
  medicamentoId    Int
  medicamento      Medicamento @relation(fields: [medicamentoId], references: [id])
  fechaVencimiento DateTime    @db.Date
  stockInicial     Int
  stockActual      Int
  descuento        Decimal     @default(0) @db.Decimal(5, 2)
  activo           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  descuentosVenta DetalleDescuentoLote[]

  @@unique([medicamentoId, codigo])
  @@index([medicamentoId, fechaVencimiento])
  @@map("lotes")
}

model Cliente {
  id              Int           @id @default(autoincrement())
  tipoDocumento   TipoDocumento
  numeroDocumento String        @unique
  nombre          String
  telefono        String?
  direccion       String?
  email           String?
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  ventas Venta[]

  @@map("clientes")
}

model Proveedor {
  id             Int      @id @default(autoincrement())
  ruc            String   @unique @db.VarChar(11)
  razonSocial    String
  asesorNombre   String?
  asesorTelefono String?
  asesorEmail    String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("proveedores")
}

model Empleado {
  id           Int      @id @default(autoincrement())
  dni          String   @unique @db.VarChar(8)
  nombre       String
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ventas Venta[]

  @@map("empleados")
}

model Venta {
  id              Int             @id @default(autoincrement())
  tipoComprobante TipoComprobante
  serie           String
  numero          Int
  metodoPago      MetodoPago
  clienteId       Int?
  cliente         Cliente?        @relation(fields: [clienteId], references: [id])
  empleadoId      Int
  empleado        Empleado        @relation(fields: [empleadoId], references: [id])
  total           Decimal         @db.Decimal(10, 2)
  createdAt       DateTime        @default(now())

  detalles DetalleVenta[]

  @@unique([serie, numero])
  @@index([createdAt])
  @@map("ventas")
}

model DetalleVenta {
  id             Int         @id @default(autoincrement())
  ventaId        Int
  venta          Venta       @relation(fields: [ventaId], references: [id])
  medicamentoId  Int
  medicamento    Medicamento @relation(fields: [medicamentoId], references: [id])
  cantidad       Int
  precioUnitario Decimal     @db.Decimal(10, 2)
  subtotal       Decimal     @db.Decimal(10, 2)

  descuentosLote DetalleDescuentoLote[]

  @@map("detalles_venta")
}

model DetalleDescuentoLote {
  id             Int          @id @default(autoincrement())
  detalleVentaId Int
  detalleVenta   DetalleVenta @relation(fields: [detalleVentaId], references: [id])
  loteId         Int
  lote           Lote         @relation(fields: [loteId], references: [id])
  cantidad       Int
  descuento      Decimal      @db.Decimal(5, 2)

  @@map("detalles_descuento_lote")
}
