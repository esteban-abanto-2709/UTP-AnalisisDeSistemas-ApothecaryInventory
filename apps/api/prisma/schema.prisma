generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  VENDEDOR
  ADMINISTRADOR
}

model Empleado {
  id           Int      @id @default(autoincrement())
  dni          String   @unique @db.VarChar(8)
  nombre       String
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("empleados")
}
